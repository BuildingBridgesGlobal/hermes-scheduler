# Hermes Scheduler — Vercel cron bridge to HuVia Core.
# Copy this file to .env and fill in real values before running.

# -----------------------------------------------------------------------------
# HuVia Core API target
# -----------------------------------------------------------------------------

HUVIA_CORE_API_URL=placeholder
HUVIA_API_KEY=placeholder

# -----------------------------------------------------------------------------
# Cron endpoint protection
# -----------------------------------------------------------------------------

# Secret used to protect cron endpoints from arbitrary HTTP calls.
CRON_SECRET=placeholder

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Request timeout (ms) when calling huvia-core. Defaults to 30000.
# HUVIA_REQUEST_TIMEOUT_MS=30000
