# HuVia Core API target
HUVIA_CORE_API_URL=https://huvia-core-api.example.com
HUVIA_API_KEY=your-huvia-core-api-key

# Secret used to protect cron endpoints from arbitrary HTTP calls
CRON_SECRET=your-vercel-cron-secret

# Optional: request timeout (ms) when calling huvia-core. Defaults to 30000.
# HUVIA_REQUEST_TIMEOUT_MS=30000
